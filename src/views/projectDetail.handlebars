<div class="container d-flex align-items-center justify-content-center gap-4 mt-5 py-5">
    {{#each project}}
    <div>
        <img src="{{this.image}}" alt="{{this.title}}" title="{{this.title}}" class="img-fluid" />
    </div>
    {{/each}}
    <div class="mt-3 rounded py-2 px-2 h-100 w-100">
        <div>
            {{#each project}}
            <h3 class="text-dark mb-3 fw-bold text-uppercase mb-4">{{title}}</h3>
            {{/each}}
        </div>
        <div class="d-flex gap-1">
            <strong class="fs-6 text-uppercase">tecnologia: </strong>
            {{#each project}}
            <h5 class="text-dark mb-4">{{tecnology}}</h5>
            {{/each}}
        </div>
        <div class="d-flex gap-1">
            <strong class="fs-6 text-uppercase">Producto vendido por: </strong>
            {{#each project}}
            <h5 class="text-dark mb-4">{{owner}}</h5>
            {{/each}}
        </div>
        <div class="d-flex gap-1">
            <strong class="fs-6 text-uppercase">Unidades disponibles: </strong>
            {{#each project}}
            <h5 class="text-dark mb-4">{{stock}}</h5>
            {{/each}}
        </div>
        <div class="d-flex">
            <strong class="fs-6 text-uppercase">Precio: $</strong>
            {{#each project}}
            <h5 class="text-dark mb-4">{{price}}</h5>
            {{/each}}
        </div>
        <div>
            <strong class="fs-6 text-uppercase">Detalle del producto:</strong>
            {{#each project}}
            <p class="text-dark fs-6 text-secondary">{{description}}</p>
            {{/each}}
        </div>
    </div>
</div>