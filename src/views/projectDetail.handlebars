<div class="container d-flex align-items-center justify-content-center gap-4 mt-5">
    <div class="mt-3 rounded py-2 px-2 h-100 w-100">
        <div>
            {{#each project}}
            <h3 class="text-dark mb-3 fw-bold text-uppercase mb-4">{{title}}</h3>
            {{/each}}
        </div>
        <div class="d-flex gap-1">
            <strong class="fs-6 text-uppercase">tecnologia: </strong>
            {{#each project}}
            <h5 class="text-dark mb-4">{{tecnology}}</h5>
            {{/each}}
        </div>
        <div>
            <strong class="fs-6 text-uppercase">Detalle del producto:</strong>
            {{#each project}}
            <p class="text-dark fs-6 text-secondary">{{description}}</p>
            {{/each}}
        </div>
    </div>
    {{#each project}}
<div>
    <img src="{{this.image}}" alt="{{this.title}}" title="{{this.title}}" class="img-fluid rounded" />
</div>
{{/each}}
</div>
<div class="d-flex align-items-center mt-3 justify-content-center gap-4">
<a href="/" class="btn btn-outline-dark">Volver al inicio</a>
<a href="/projects" class="btn btn-outline-dark">Volver al Portafolio</a>
</div>